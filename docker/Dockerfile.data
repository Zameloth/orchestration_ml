FROM ghcr.io/astral-sh/uv:python3.13-bookworm-slim

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN uv sync --extra data --no-dev --frozen --no-install-project
RUN uv pip install --no-cache "kaggle<1.6"

COPY src/ ./src/
COPY docker/download_data.sh /download_data.sh
RUN chmod +x /download_data.sh

ENV PYTHONPATH=/app/src
ENV PATH="/app/.venv/bin:$PATH"

ENTRYPOINT ["/bin/sh", "/download_data.sh"]
